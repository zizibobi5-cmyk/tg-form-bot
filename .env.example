# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID канала, куда публикуются принятые анкеты.
# Бот должен быть админом канала с правом публикации сообщений.
# Получить ID: переслать любое сообщение из канала боту @userinfobot,
# либо использовать @username_to_id_bot. Для приватных каналов формат -100xxxxxxxxxx
CHANNEL_ID=-1001234567890

# ID чата модераторов (группа, куда приходят анкеты на проверку).
# Бот должен быть добавлен в группу. ID получить через @userinfobot
# (переслать туда сообщение из группы) или временно включить отладку.
MODERATOR_CHAT_ID=-1009876543210

# ID администраторов через запятую. Это пользователи Telegram,
# которые могут управлять списком модераторов, банить и смотреть статистику.
ADMIN_IDS=111111111,222222222

# Подключение к БД.
# Для локального запуска подойдёт SQLite (по умолчанию):
DATABASE_URL=sqlite+aiosqlite:///data/bot.db
# Для продакшена (Neon, Supabase, любой Postgres) — строка подключения вида:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# Префикс postgresql:// автоматически конвертируется в postgresql+asyncpg://,
# параметр sslmode тоже срезается (asyncpg включает SSL сам).

# Антифлуд: минимальный интервал между сообщениями пользователя в секундах
ANTIFLOOD_SECONDS=3

# Максимальное количество принятых анкет на одного пользователя
MAX_APPROVED_PER_USER=30

# Максимальное количество фото в анкете
MAX_PHOTOS=10

# Минимальное количество фото в анкете
MIN_PHOTOS=1

# Ссылка на правила (опционально). Если пусто — будет показан текст из texts.py
RULES_URL=

# Задержка (сек) между текстовыми сообщениями при публикации в канал.
# Нужна, чтобы не словить флуд-лимиты Telegram при длинных анкетах (2-3 сообщения подряд).
CHANNEL_DELAY_BETWEEN_TEXTS=5

# Задержка (сек) между текстовой частью и фотоальбомом при публикации в канал.
# Сначала уходит текст, потом пауза, потом фото.
CHANNEL_DELAY_BEFORE_PHOTOS=15

# ===== Telethon юзербот (опционально) =====
# Если true — бот не публикует анкеты в канал сам, а кладёт их в очередь
# channel_publications. Отдельный сервис userbot.main (Telethon, логин под
# Premium-аккаунтом) забирает задачи и публикует от твоего имени, сохраняя
# премиум/кастомные эмодзи. Если false (по умолчанию) — бот публикует сам,
# как раньше, но премиум-эмодзи режутся (это ограничение Telegram для ботов).
USERBOT_ENABLED=false

# ===== Переменные ТОЛЬКО для сервиса tg-form-userbot =====
# Они НЕ нужны самому боту, но юзербот их требует.
#
# Получить TELEGRAM_API_ID/HASH:
#   https://my.telegram.org → API development tools → создать приложение.
# TELEGRAM_API_ID — число.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
#
# TELEGRAM_SESSION — это StringSession Telethon. Сгенерировать локально:
#   pip install telethon
#   export TELEGRAM_API_ID=...
#   export TELEGRAM_API_HASH=...
#   python scripts/generate_session.py
# (потребуется код из Telegram). Получившуюся одну длинную строку положите
# сюда / в переменные окружения Render.
TELEGRAM_SESSION=

# Интервал опроса очереди публикаций (сек). По умолчанию 5.
USERBOT_POLL_INTERVAL=5

# Уровень логов юзербота. INFO достаточно для прод. DEBUG — для отладки.
USERBOT_LOG_LEVEL=INFO
